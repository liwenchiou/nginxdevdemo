# 這裡是定義上游 (Upstream) 伺服器群組的地方，也是 Nginx 負載均衡的核心。
# 這個檔案是由 docker-gen 自動生成的，請勿手動修改！

upstream api_servers {
{{ $containers := whereLabelExists $ "demo_api" }}
{{ if not $containers }}
    # 當沒有任何 API 伺服器存活時的 Fallback 保護，防止 Nginx 因為 upstream 區塊為空而啟動失敗
    server 127.0.0.1:65535 down;
{{ else }}
{{ range $container := $containers }}
    # 自動偵測到的容器名稱: {{ $container.Name }}
    {{ range $network := $container.Networks }}
    server {{ $network.IP }}:3000 max_fails=1 fail_timeout=5s;
    {{ end }}
{{ end }}
{{ end }}
}
